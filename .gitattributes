# Shell scripts and launchd plists must stay LF or they break on macOS/Linux
*.sh text eol=lf
*.plist text eol=lf
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
vendor/*.js text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
*.yml text eol=lf
# Windows-native scripts keep CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
